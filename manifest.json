{
  "manifest_version": 3,
  "name": "개드립 읽음 동기화",
  "key": "",
  "version": "1.0.0",
  "description": "dogdrip.net 읽은 게시물을 여러 기기에서 Google Drive로 동기화합니다.",
  "permissions": ["storage", "identity", "alarms"],
  "host_permissions": [
    "https://www.dogdrip.net/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.dogdrip.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "개드립 읽음 동기화"
  }
}
