{
  "manifest_version": 3,
  "name": "dogdrip-helper",
  "key": "",
  "version": "1.0.0",
  "description": "dogdrip.net 사용에 도움되는 기능을 제공하는 확장프로그램",
  "permissions": ["storage", "identity", "alarms"],
  "host_permissions": [
    "https://www.dogdrip.net/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.dogdrip.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "dogdrip-helper"
  }
}
